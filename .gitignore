# macOS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Python cache / build output
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/

# Local environments
.venv/
venv/
env/
.env
.env.*

# Logs and temporary files
*.log
*.tmp
*.bak

# Large raw media generated during experiments.
# CSV / JSON / small model bundles under yolo/results are intentionally tracked.
*.mp4
*.mov
*.avi
*.mkv

# Downloaded foundation / detector weights should be fetched locally.
# Keep yolo/results/bridge_models_final/model_bundle.pth trackable.
yolov8*.pt
*.onnx
*.engine

# Office lock files and local exported documents.
~$*.docx
~$*.xlsx
~$*.pptx
*.docx
*.pdf
